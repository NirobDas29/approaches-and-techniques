#include<bits/stdc++.h>
#include <vector>

using namespace std;

// remember two pointer only runs for sorted array
class Solution {
public:
    vector<int> twoSum(vector<int>& numbers, int target) {
        int n = numbers.size();
        int left = 0;
        int right = n - 1;
        while (left < right) {
            int sum = numbers[left] + numbers[right];
            if (sum == target) {
                return {left + 1, right + 1};
            }
            if (sum < target) {
                left++;
            } else {
                right--;
            }
        }
        return {};
    }
};

int main() {
    int n;
    if (!(cin >> n)) {
        return 0;
    }
    vector<int> numbers(n);
    for (int i = 0; i < n; i++) {
        cin >> numbers[i];
    }
    int target;
    cin >> target;
    Solution solution;
    vector<int> result = solution.twoSum(numbers, target);
    if (result.size() == 2) {
        cout << result[0] << " " << result[1];
    } else {
        cout << "-1 -1";
    }
    return 0;
}
